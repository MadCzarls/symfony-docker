{% extends 'base.html.twig' %}

{% block title %}Hello AppController!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">

    <a href="{{ path('movies_list') }}">To movie list</a>
    <h1>Hello {{ controller_name }}! ✅</h1>
    <h1>Hello {{ testVar }}! ✅</h1>

    {% include('test/_form.html.twig') %}

    This friendly message is coming from:
    <ul>
        <li>Your controller at <code><a href="{{ '/var/www/app/src/Controller/AppController.php'|file_link(0) }}">src/Controller/AppController.php</a></code></li>
        <li>Your template at <code><a href="{{ '/var/www/app/templates/test/index.html.twig'|file_link(0) }}">templates/test/index.html.twig</a></code></li>
    </ul>
</div>
{% endblock %}
